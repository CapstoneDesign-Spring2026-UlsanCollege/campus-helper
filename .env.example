# MongoDB (required for most API routes at runtime)
MONGODB_URI=

# Redis (required in production for login rate limiting; optional in local dev)
REDIS_URL=

OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Cloudinary (required for uploads like notes + profile photos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT secrets (required)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Used for absolute links (password reset, etc.)
NEXT_PUBLIC_APP_URL=
APP_URL=

# Email (optional; password reset emails only send when configured)
SMTP_USER=
SMTP_PASS=
